# Copy to .env.local for local dev. Never commit .env.local.
# In production these are set via `wrangler pages secret put <NAME>`.

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Clerk (client portal auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Google Drive (service account) ---
# Paste the full JSON of the service-account credentials as a single-line string.
GOOGLE_SERVICE_ACCOUNT_JSON={}
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx
ORDER_NOTIFY_EMAIL=noorktransports@gmail.com
